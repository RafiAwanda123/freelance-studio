<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_task_deadline_reminder" model="mail.template">
            <field name="name">Task Deadline Reminder</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="subject">Pengingat: {{ object.name }} Deadline Besok!</field>
            <field name="email_from">{{ (object.user_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.user_id.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 14px; color: #444;">
                    <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
                        <!-- Header -->
                        <div style="background-color: #875A7B; padding: 20px; text-align: center;">
                            <h2 style="margin: 0; color: #ffffff; font-size: 20px;">Task Deadline Reminder</h2>
                        </div>
                        
                        <!-- Content -->
                        <div style="padding: 30px;">
                            <p style="margin-top: 0;">Halo <strong><t t-out="object.user_id.name or 'Designer'"/></strong>,</p>
                            
                            <p>Ini adalah pengingat otomatis bahwa task berikut akan berakhir besok:</p>
                            
                            <div style="background-color: #f8f9fa; border-left: 4px solid #875A7B; padding: 15px; margin: 20px 0;">
                                <p style="margin: 5px 0;"><strong>Task:</strong> <t t-out="object.name"/></p>
                                <p style="margin: 5px 0;"><strong>Client:</strong> <t t-out="object.partner_id.name or 'Belum ditentukan'"/></p>
                                <p style="margin: 5px 0;"><strong>Project:</strong> <t t-out="object.project_id.name"/></p>
                                <p style="margin: 5px 0;"><strong>Deadline:</strong> <span style="color: #dc3545; font-weight: bold;"><t t-out="object.date_deadline"/></span></p>
                            </div>
                            
                            <p>Mohon pastikan progress sudah sesuai target. Semangat berkarya!</p>
                            
                            <div style="margin-top: 30px; text-align: center;">
                                <a t-att-href="object.get_base_url() + '/web#id=' + str(object.id) + '&amp;model=project.task&amp;view_type=form'" 
                                   style="background-color: #875A7B; color: #ffffff; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold;">
                                   Cek Project Sekarang
                                </a>
                            </div>
                        </div>
                        
                        <!-- Footer -->
                        <div style="background-color: #f1f1f1; padding: 15px; text-align: center; font-size: 12px; color: #888;">
                            <p style="margin: 0;">Freelance Studio Automation System</p>
                        </div>
                    </div>
                </div>
            </field>
        </record>
    </data>
</odoo>
