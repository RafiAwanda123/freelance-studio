<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_task_deadline_reminder" model="ir.cron">
            <field name="name">Freelance: Send Task Deadline Reminders</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="state">code</field>
            <field name="code">model.action_send_deadline_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="nextcall">2026-02-20 22:00:00</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
